rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'student')
    //   - name: string (required)
    //   - course: string (optional)
    //   - group: string (optional)
    //   - createdAt: string (required)
    // Collection: ingredients
    //   - nameES: string (required)
    //   - nameEN: string (optional)
    //   - unit: string (required, 'kg', 'g', 'l', 'ml', 'ud')
    //   - costPerUnit: number (required)
    //   - createdBy: string (required)
    //   - createdAt: string (required)
    // Collection: recipes
    //   - nameES: string (required)
    //   - nameEN: string (optional)
    //   - descriptionES: string (optional)
    //   - descriptionEN: string (optional)
    //   - steps: list (optional)
    //   - stepsEN: list (optional)
    //   - equipment: list (optional)
    //   - sustainabilityTips: list (optional)
    //   - ingredients: list (required)
    //   - totalCost: number (required)
    //   - createdBy: string (required)
    //   - createdAt: string (required)
    // Collection: menus
    //   - nameES: string (required)
    //   - nameEN: string (optional)
    //   - type: string (required, 'brunch', 'cocktail')
    //   - targetClient: string (optional)
    //   - location: string (optional)
    //   - occasion: string (optional)
    //   - recipes: list (required)
    //   - totalCost: number (required)
    //   - price: number (required)
    //   - createdBy: string (required)
    //   - createdAt: string (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "lsuarodzmail.com@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin')
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "lsuarodzmail.com@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['admin', 'docente'])
      );
    }

    function isStudentOrAdmin() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role in ['admin', 'student', 'docente'])
      );
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().removeAll(allowedFields).size() == 0;
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['email', 'role', 'name', 'course', 'group', 'commission', 'createdAt']) &&
             isValidString(data.email, 3, 100) &&
             data.role in ['admin', 'student', 'docente'] &&
             isValidString(data.name, 1, 100) &&
             (!('course' in data) || data.course == "" || isValidString(data.course, 1, 50)) &&
             (!('group' in data) || data.group == "" || isValidString(data.group, 1, 50)) &&
             (!('commission' in data) || data.commission == "" || isValidString(data.commission, 1, 50)) &&
             data.createdAt is string;
    }

    function isValidIngredient() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['nameES', 'nameEN', 'unit', 'costPerUnit', 'purchasePrice', 'wastePercentage', 'provider', 'purchaseFormat', 'weightPerUnit', 'formatPrice', 'format', 'allergens', 'createdBy', 'createdAt']) &&
             isValidString(data.nameES, 1, 100) &&
             (!('nameEN' in data) || data.nameEN == "" || isValidString(data.nameEN, 1, 100)) &&
             data.unit in ['kg', 'L', 'g', 'l', 'ml', 'ud'] &&
             data.costPerUnit is number && data.costPerUnit >= 0 &&
             (!('purchasePrice' in data) || (data.purchasePrice is number && data.purchasePrice >= 0)) &&
             (!('wastePercentage' in data) || (data.wastePercentage is number && data.wastePercentage >= 0 && data.wastePercentage <= 99)) &&
             (!('provider' in data) || data.provider == "" || isValidString(data.provider, 1, 100)) &&
             (!('purchaseFormat' in data) || data.purchaseFormat == "" || isValidString(data.purchaseFormat, 1, 150)) &&
             (!('weightPerUnit' in data) || (data.weightPerUnit is number && data.weightPerUnit >= 0)) &&
             (!('formatPrice' in data) || (data.formatPrice is number && data.formatPrice >= 0)) &&
             (!('format' in data) || data.format == "" || isValidString(data.format, 1, 100)) &&
             (!('allergens' in data) || data.allergens is list) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidRecipe() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['nameES', 'nameEN', 'descriptionES', 'descriptionEN', 'steps', 'stepsEN', 'equipment', 'miseEnPlace', 'sustainabilityTips', 'ingredients', 'totalCost', 'createdBy', 'group', 'score', 'feedback', 'createdAt', 'portions', 'imageUrl', 'type', 'yieldQuantity', 'yieldUnit']) &&
             isValidString(data.nameES, 1, 100) &&
             (!('nameEN' in data) || data.nameEN == "" || isValidString(data.nameEN, 1, 100)) &&
             (!('descriptionES' in data) || data.descriptionES == "" || isValidString(data.descriptionES, 1, 2000)) &&
             (!('descriptionEN' in data) || data.descriptionEN == "" || isValidString(data.descriptionEN, 1, 2000)) &&
             (!('steps' in data) || data.steps is list) &&
             (!('stepsEN' in data) || data.stepsEN is list) &&
             (!('equipment' in data) || data.equipment is list) &&
             (!('miseEnPlace' in data) || data.miseEnPlace == "" || isValidString(data.miseEnPlace, 1, 2000)) &&
             (!('sustainabilityTips' in data) || data.sustainabilityTips is list) &&
             (!('imageUrl' in data) || data.imageUrl == "" || isValidString(data.imageUrl, 1, 2000)) &&
             (!('type' in data) || data.type in ['elaborado', 'plato']) &&
             (!('yieldUnit' in data) || data.yieldUnit in ['kg', 'L', 'ud']) &&
             (!('yieldQuantity' in data) || data.yieldQuantity == null || (data.yieldQuantity is number && data.yieldQuantity >= 0)) &&
             data.ingredients is list && data.ingredients.size() <= 100 &&
             data.totalCost is number && data.totalCost >= 0 &&
             isValidString(data.createdBy, 1, 100) &&
             (!('group' in data) || data.group == "" || isValidString(data.group, 1, 50)) &&
             (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 10)) &&
             (!('feedback' in data) || data.feedback == "" || isValidString(data.feedback, 1, 2000)) &&
             data.createdAt is string &&
             (!('portions' in data) || data.portions == null || (data.portions is number && data.portions > 0));
    }

    function isValidMenu() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['nameES', 'nameEN', 'eventDate', 'eventTime', 'eventPlace', 'type', 'clientId', 'location', 'occasion', 'recipes', 'totalCost', 'price', 'createdBy', 'group', 'score', 'feedback', 'createdAt', 'diners']) &&
             isValidString(data.nameES, 1, 100) &&
             (!('nameEN' in data) || data.nameEN == "" || isValidString(data.nameEN, 1, 100)) &&
             (!('eventDate' in data) || data.eventDate == "" || isValidString(data.eventDate, 1, 100)) &&
             (!('eventTime' in data) || data.eventTime == "" || isValidString(data.eventTime, 1, 50)) &&
             (!('eventPlace' in data) || data.eventPlace == "" || isValidString(data.eventPlace, 1, 150)) &&
             data.type in ['brunch', 'cocktail', 'navidad', 'coffee', 'cafeteria', 'pedagogico'] &&
             (!('clientId' in data) || data.clientId == "" || isValidString(data.clientId, 1, 100)) &&
             (!('location' in data) || data.location in ['centro', 'fuera']) &&
             (!('occasion' in data) || data.occasion == "" || isValidString(data.occasion, 1, 100)) &&
             data.recipes is list && data.recipes.size() <= 50 &&
             data.totalCost is number && data.totalCost >= 0 &&
             data.price is number && data.price >= 0 &&
             isValidString(data.createdBy, 1, 100) &&
             (!('group' in data) || data.group == "" || isValidString(data.group, 1, 50)) &&
             (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 10)) &&
             (!('feedback' in data) || data.feedback == "" || isValidString(data.feedback, 1, 2000)) &&
             data.createdAt is string &&
             (!('diners' in data) || data.diners == null || (data.diners is number && data.diners > 0));
    }

    function isValidIdeaVote() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['ideaId', 'userId', 'userName', 'score', 'reason', 'createdAt']) &&
             isValidString(data.ideaId, 1, 100) &&
             isValidString(data.userId, 1, 100) &&
             isValidString(data.userName, 1, 100) &&
             data.score is number && data.score >= 1 && data.score <= 5 &&
             isValidString(data.reason, 1, 1000) &&
             data.createdAt is string;
    }

    function isValidProvider() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'name', 'contactName', 'phone', 'email', 'goodsType', 'address', 'notes', 'createdBy', 'createdAt']) &&
             isValidString(data.name, 1, 150) &&
             (!('id' in data) || isValidString(data.id, 1, 100)) &&
             (!('contactName' in data) || data.contactName == "" || isValidString(data.contactName, 1, 150)) &&
             (!('phone' in data) || data.phone == "" || isValidString(data.phone, 1, 50)) &&
             (!('email' in data) || data.email == "" || isValidString(data.email, 1, 150)) &&
             (!('goodsType' in data) || data.goodsType == "" || isValidString(data.goodsType, 1, 100)) &&
             (!('address' in data) || data.address == "" || isValidString(data.address, 1, 300)) &&
             (!('notes' in data) || data.notes == "" || isValidString(data.notes, 1, 1000)) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidStandardWaste() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'item', 'percentage', 'notes', 'createdBy', 'createdAt']) &&
             isValidString(data.item, 1, 150) &&
             (!('id' in data) || isValidString(data.id, 1, 100)) &&
             data.percentage is number && data.percentage >= 0 && data.percentage <= 99 &&
             (!('notes' in data) || data.notes == "" || isValidString(data.notes, 1, 1000)) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidClient() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'name', 'contactName', 'phone', 'email', 'company', 'address', 'notes', 'createdBy', 'createdAt']) &&
             isValidString(data.name, 1, 150) &&
             (!('id' in data) || isValidString(data.id, 1, 100)) &&
             (!('contactName' in data) || data.contactName == "" || isValidString(data.contactName, 1, 150)) &&
             (!('phone' in data) || data.phone == "" || isValidString(data.phone, 1, 50)) &&
             (!('email' in data) || data.email == "" || isValidString(data.email, 1, 150)) &&
             (!('company' in data) || data.company == "" || isValidString(data.company, 1, 150)) &&
             (!('address' in data) || data.address == "" || isValidString(data.address, 1, 300)) &&
             (!('notes' in data) || data.notes == "" || isValidString(data.notes, 1, 1000)) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidQuote() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'reference', 'clientId', 'date', 'eventDate', 'eventType', 'guests', 'items', 'subtotal', 'tax', 'total', 'notes', 'status', 'createdBy', 'createdAt']) &&
             (!('id' in data) || isValidString(data.id, 1, 100)) &&
             (!('reference' in data) || data.reference == "" || isValidString(data.reference, 1, 100)) &&
             isValidString(data.clientId, 1, 100) &&
             isValidString(data.date, 1, 100) &&
             (!('eventDate' in data) || data.eventDate == "" || isValidString(data.eventDate, 1, 100)) &&
             (!('eventType' in data) || data.eventType == "" || isValidString(data.eventType, 1, 150)) &&
             (!('guests' in data) || data.guests is number) &&
             data.items is list &&
             data.subtotal is number &&
             data.tax is number &&
             data.total is number &&
             data.status in ['draft', 'sent', 'accepted', 'rejected'] &&
             (!('notes' in data) || data.notes == "" || isValidString(data.notes, 1, 2000)) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidProductionIdea() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['id', 'menuId', 'idea', 'referenceLink', 'createdBy', 'createdAt']) &&
             (!('id' in data) || isValidString(data.id, 1, 100)) &&
             isValidString(data.menuId, 1, 100) &&
             isValidString(data.idea, 1, 2000) &&
             (!('referenceLink' in data) || data.referenceLink == null || data.referenceLink == "" || isValidString(data.referenceLink, 1, 2000)) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    function isValidCommissionTask() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['commission', 'idea', 'createdBy', 'createdAt']) &&
             isValidString(data.commission, 1, 50) &&
             isValidString(data.idea, 1, 1000) &&
             isValidString(data.createdBy, 1, 100) &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isStudentOrAdmin() || request.auth.token.email == userId;
      allow create, update: if isAdmin() && isValidUser();
      allow delete: if isSuperAdmin();
    }

    match /ingredients/{ingredientId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidIngredient();
      allow delete: if isSuperAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidRecipe();
      allow delete: if isSuperAdmin();
    }

    match /menus/{menuId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidMenu();
      allow delete: if isSuperAdmin();
    }

    match /jornada1_ideas/{ideaId} {
      allow read: if isStudentOrAdmin();
      allow create: if isStudentOrAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /jornada1_characteristics/{charId} {
      allow read: if isStudentOrAdmin();
      allow create: if isStudentOrAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /jornada1_standardization/{userId} {
      allow read: if isStudentOrAdmin() && (request.auth.uid == userId || isAdmin() || request.auth.token.email == userId);
      allow create, update: if isStudentOrAdmin() && (request.auth.uid == userId || request.auth.token.email == userId);
      allow delete: if isSuperAdmin();
    }

    match /work_team_submissions/{userId} {
      allow read: if isStudentOrAdmin() && (request.auth.uid == userId || isAdmin() || request.auth.token.email == userId);
      allow create, update: if isStudentOrAdmin() && (request.auth.uid == userId || request.auth.token.email == userId);
      allow delete: if isSuperAdmin();
    }

    match /benchmarking_companies/{companyId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin();
      allow delete: if isStudentOrAdmin();
    }

    match /benchmarking_ideas/{ideaId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin();
      allow delete: if isStudentOrAdmin();
    }

    match /benchmarking_sources/{sourceId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin();
      allow delete: if isStudentOrAdmin();
    }

    match /production_ideas/{ideaId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidProductionIdea();
      allow delete: if isStudentOrAdmin();
    }

    match /idea_votes/{voteId} {
      allow read: if isStudentOrAdmin();
      allow create: if isStudentOrAdmin() && isValidIdeaVote() && request.auth.uid == request.resource.data.userId;
      allow update: if isStudentOrAdmin() && isValidIdeaVote() && request.auth.uid == resource.data.userId && request.auth.uid == request.resource.data.userId;
      allow delete: if isStudentOrAdmin() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /providers/{providerId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidProvider();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /standard_wastes/{wasteId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidStandardWaste();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidClient();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidQuote();
      allow delete: if isSuperAdmin() || isAdmin();
    }

    match /commission_tasks/{taskId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isStudentOrAdmin() && isValidCommissionTask();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isStudentOrAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
