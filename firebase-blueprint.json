{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (Admin or Student)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "student", "docente"] },
        "name": { "type": "string" },
        "course": { "type": "string" },
        "group": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "name", "createdAt"]
    },
    "Ingredient": {
      "title": "Ingredient",
      "description": "An ingredient used in recipes",
      "type": "object",
      "properties": {
        "nameES": { "type": "string" },
        "nameEN": { "type": "string" },
        "provider": { "type": "string" },
        "purchaseFormat": { "type": "string" },
        "weightPerUnit": { "type": "number" },
        "formatPrice": { "type": "number" },
        "format": { "type": "string" },
        "allergens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unit": { "type": "string", "enum": ["kg", "g", "l", "ml", "ud"] },
        "purchasePrice": { "type": "number" },
        "wastePercentage": { "type": "number" },
        "costPerUnit": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameES", "unit", "costPerUnit", "createdBy", "createdAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A recipe or escandallo",
      "type": "object",
      "properties": {
        "nameES": { "type": "string" },
        "nameEN": { "type": "string" },
        "descriptionES": { "type": "string" },
        "descriptionEN": { "type": "string" },
        "type": { "type": "string", "enum": ["elaborado", "plato"] },
        "yieldQuantity": { "type": "number" },
        "yieldUnit": { "type": "string", "enum": ["kg", "L", "ud"] },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stepsEN": {
          "type": "array",
          "items": { "type": "string" }
        },
        "equipment": {
          "type": "array",
          "items": { "type": "string" }
        },
        "miseEnPlace": { "type": "string" },
        "sustainabilityTips": {
          "type": "array",
          "items": { "type": "string" }
        },
        "imageUrl": { "type": "string" },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ingredientId": { "type": "string" },
              "quantity": { "type": "number" }
            },
            "required": ["ingredientId", "quantity"]
          }
        },
        "totalCost": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameES", "ingredients", "totalCost", "createdBy", "createdAt"]
    },
    "Menu": {
      "title": "Menu",
      "description": "A brunch or cocktail menu",
      "type": "object",
      "properties": {
        "nameES": { "type": "string" },
        "nameEN": { "type": "string" },
        "eventDate": { "type": "string" },
        "eventTime": { "type": "string" },
        "eventPlace": { "type": "string" },
        "type": { "type": "string", "enum": ["brunch", "cocktail"] },
        "targetClient": { "type": "string" },
        "location": { "type": "string", "enum": ["centro", "fuera"] },
        "occasion": { "type": "string" },
        "recipes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "totalCost": { "type": "number" },
        "price": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameES", "type", "recipes", "totalCost", "price", "createdBy", "createdAt"]
    },
    "ProductionIdea": {
      "title": "ProductionIdea",
      "description": "A brainstorming idea for a menu",
      "type": "object",
      "properties": {
        "menuId": { "type": "string" },
        "idea": { "type": "string" },
        "referenceLink": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["menuId", "idea", "createdBy", "createdAt"]
    },
    "IdeaVote": {
      "title": "IdeaVote",
      "description": "A vote/rating for a dish idea",
      "type": "object",
      "properties": {
        "ideaId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "score": { "type": "number", "minimum": 1, "maximum": 5 },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ideaId", "userId", "userName", "score", "reason", "createdAt"]
    },
    "Provider": {
      "title": "Provider",
      "description": "A supplier or provider of goods",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "goodsType": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "createdAt"]
    },
    "StandardWaste": {
      "title": "StandardWaste",
      "description": "Standardized waste percentage for an item",
      "type": "object",
      "properties": {
        "item": { "type": "string" },
        "percentage": { "type": "number" },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["item", "percentage", "createdBy", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "A client of the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "createdAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote or budget for a client event",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "reference": { "type": "string" },
        "date": { "type": "string" },
        "eventDate": { "type": "string" },
        "eventType": { "type": "string" },
        "guests": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            },
            "required": ["description", "quantity", "unitPrice", "total"]
          }
        },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "rejected"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "date", "items", "subtotal", "tax", "total", "status", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "ingredients/{ingredientId}": {
      "schema": { "$ref": "#/entities/Ingredient" },
      "description": "Ingredients collection"
    },
    "recipes/{recipeId}": {
      "schema": { "$ref": "#/entities/Recipe" },
      "description": "Recipes collection"
    },
    "menus/{menuId}": {
      "schema": { "$ref": "#/entities/Menu" },
      "description": "Menus collection"
    },
    "idea_votes/{voteId}": {
      "schema": { "$ref": "#/entities/IdeaVote" },
      "description": "Votes for dish ideas"
    },
    "providers/{providerId}": {
      "schema": { "$ref": "#/entities/Provider" },
      "description": "Providers collection"
    },
    "standard_wastes/{wasteId}": {
      "schema": { "$ref": "#/entities/StandardWaste" },
      "description": "Standardized wastes collection"
    },
    "production_ideas/{ideaId}": {
      "schema": { "$ref": "#/entities/ProductionIdea" },
      "description": "Production brainstorming ideas"
    },
    "clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Clients collection"
    },
    "quotes/{quoteId}": {
      "schema": { "$ref": "#/entities/Quote" },
      "description": "Quotes collection"
    }
  }
}
